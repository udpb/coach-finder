# =============================================================================
# coach-finder env vars
#
# Copy this to .env.local and fill in real values for local development.
# In production these go in Vercel → Project Settings → Environment Variables.
#
# Categories:
#   1. Existing Firebase (Firestore overlay only — auth migrated in C4)
#   2. Existing Python AI backend (FAISS RAG, Cloud Run)
#   3. Phase C1: Supabase coaches_directory (server-side service role)
#   4. Phase C4: Supabase Auth + browser data fetch (anon key, browser-safe)
# =============================================================================

# ── 1. Firebase (client) ────────────────────────────────────────────────────
# After Phase C4, Firebase Auth is no longer used; these are kept ONLY because
# CoachDataContext + ProjectContext still read/write the Firestore overlay.
# Removing them is deferred to a later phase (Firestore data migration).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# ── 2. Python AI backend (Cloud Run, used for /api/v1/recommend etc.) ───────
VITE_API_BASE_URL="https://underdogs-ai-backend-103534218514.asia-northeast3.run.app"

# ── 3. Phase C1: Supabase (server-side only — DO NOT use VITE_ prefix) ──────
# The coach pool now lives in public.coaches_directory. The /api/coaches
# serverless function reads it with the service-role key (bypasses RLS so
# it can serve unauthenticated coach-finder users on Firebase Auth).
#
# Project URL: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
#
# Service role key: Supabase Dashboard → Project Settings → API →
#   Project API keys → service_role → "Reveal" → copy.
# NEVER expose this to the browser. NEVER prefix with VITE_.
# NEVER commit the real value.
SUPABASE_SERVICE_ROLE=""

# ── 4. Phase C4: Supabase Auth + browser data fetch (anon key, browser-safe) ─
# Same Supabase project as coaching-log — both apps share auth.users +
# public.profiles, so the same email = same identity = same role.
#
# Project URL: same as SUPABASE_URL above
# (e.g. https://zwvrtxxgctyyctirntzj.supabase.co).
VITE_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
#
# Anon (publishable) key: Supabase Dashboard → Project Settings → API →
#   Project API keys → anon → "Reveal" → copy.
# This IS browser-safe (RLS protects the data). Do NOT use service_role here.
VITE_SUPABASE_ANON_KEY=""
